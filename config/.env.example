# GitHub Agent V2 - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# GitHub App Configuration
# ============================================
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY_PATH=/home/tj/.github/github-app-key.pem
WEBHOOK_SECRET=your-webhook-secret

# ============================================
# OpenClaw Cloud Agent (Intent Recognition)
# ============================================
OPENCLAW_API_URL=http://localhost:3000/api/v1
# OPENCLAW_API_KEY=optional-api-key

# ============================================
# Knowledge Base Service
# ============================================
KB_SERVICE_ENABLED=true
KB_SERVICE_URL=http://localhost:8000
KB_SIMILARITY_THRESHOLD=0.7
KB_TOP_K=3

# ============================================
# Code Executor (Ollama)
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
OLLAMA_TEMPERATURE=0.3

# ============================================
# Trigger Mode Configuration
# ============================================
# Issue trigger mode: auto (all issues) / smart (only with @agent)
GITHUB_AGENT_ISSUE_TRIGGER_MODE=smart

# Comment trigger mode: smart (only with @agent) / all (any comment)
GITHUB_AGENT_COMMENT_TRIGGER_MODE=smart

# Confirmation mode: auto (direct execute) / manual (wait for confirmation)
AGENT_CONFIRM_MODE=auto
AGENT_AUTO_CONFIRM_THRESHOLD=0.8

# ============================================
# Webhook Server
# ============================================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# ============================================
# Working Directories
# ============================================
GITHUB_AGENT_WORKDIR=/tmp/github-agent-v2
GITHUB_AGENT_WEBHOOK_DIR=/tmp/github-webhooks-v2
