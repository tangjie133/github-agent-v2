# GitHub Agent V2 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================
# GitHub App 配置（必需）
# ============================================
GITHUB_APP_ID=your_app_id_here
GITHUB_PRIVATE_KEY_PATH=/path/to/private-key.pem
# 或者直接使用私钥内容（不推荐）
# GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Webhook 服务器配置
# ============================================
GITHUB_AGENT_HOST=0.0.0.0
GITHUB_AGENT_PORT=8080
# Webhook 事件保存目录（用于调试和审计，可选）
# GITHUB_AGENT_WEBHOOK_DIR=/tmp/github-webhooks-v2

# ============================================
# 触发模式配置
# ============================================
# Issue 触发模式: auto(所有), smart(需@agent), manual(手动)
GITHUB_AGENT_ISSUE_TRIGGER_MODE=smart
# 评论触发模式: all(所有), smart(需@agent), manual(手动)  
GITHUB_AGENT_COMMENT_TRIGGER_MODE=smart

# ============================================
# 确认模式配置
# ============================================
# 确认模式: auto(自动执行), manual(需用户确认)
AGENT_CONFIRM_MODE=auto
# 自动确认置信度阈值 (0-1)
AGENT_AUTO_CONFIRM_THRESHOLD=0.8

# ============================================
# Issue 跟踪功能配置
# ============================================
# 是否启用 Issue 跟踪功能（自动关闭已解决的 Issue）
# true: 启用 - 检测用户回复"已解决"等关键词后自动关闭 Issue
# false: 禁用 - 不自动关闭 Issue，仅回复确认消息
AGENT_ISSUE_TRACKING_ENABLED=true

# ============================================
# OpenClaw 配置 (云端意图识别)
# ============================================
OPENCLAW_URL=http://localhost:3000
OPENCLAW_MODEL=kimi-k2.5
OPENCLAW_TIMEOUT=60

# ============================================
# Ollama 配置 (本地代码生成)
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
OLLAMA_TIMEOUT=300

# ============================================
# 知识库服务配置 (可选)
# ============================================
# 知识库服务连接地址（用于连接已有服务）
KB_SERVICE_URL=http://localhost:8000
# 知识库服务监听配置（用于启动服务）
# KB_SERVICE_HOST=0.0.0.0
# KB_SERVICE_PORT=8000

# 嵌入模型配置（通过 Ollama）
# KB_EMBEDDING_MODEL=bge-m3:latest
# KB_EMBEDDING_HOST=http://localhost:11434

KB_TIMEOUT=30
# 知识库本地数据存储目录（可选）
# KB_DATA_DIR=./knowledge_base/data
# 知识库相似度匹配阈值 (0-1，可选)
# KB_SIMILARITY_THRESHOLD=0.7
# 是否启用知识库功能 (true/false，可选)
# KB_ENABLED=true

# ============================================
# GitHub 知识库同步配置 (可选)
# ============================================
# 启用 GitHub 仓库同步
KB_GITHUB_SYNC_ENABLED=true
# GitHub 仓库地址 (格式: owner/repo)
KB_REPO=tangjie133/knowledge-base
# 分支名称
KB_BRANCH=main
# GitHub Token（用于 API 认证，避免速率限制）
# 获取方式: GitHub Settings → Developer settings → Personal access tokens → Tokens (classic)
# 权限要求: 只需要 'public_repo' 或 'repo'（私有仓库）
# 速率限制: 未认证 60次/小时，认证后 5000次/小时
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx
# 自动同步间隔（秒），0 表示不同步
KB_SYNC_INTERVAL=0
# 启用 Webhook 实时同步
KB_WEBHOOK_ENABLED=true

# ============================================
# 成功案例存储配置 (Phase 1-2)
# ============================================
# 启用后，代码修改成功会自动保存案例到本地知识库
# 并同步到 KB_REPO 配置的 GitHub 仓库
# 本地存储路径（可选，默认: knowledge_base/data/cases）
# KB_STORAGE_PATH=./knowledge_base/data/cases
# 是否启用自动同步到远程仓库
KB_AUTO_SYNC=true
# 同步失败重试次数
KB_SYNC_MAX_RETRIES=3
KB_WEBHOOK_PORT=9000
KB_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# 工作目录配置
# ============================================
GITHUB_AGENT_WORKDIR=/home/tj/github-agent-v2
GITHUB_AGENT_STATEDIR=/home/tj/state

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
# 日志输出格式（Python logging 格式，可选）
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_FILE=/var/log/github-agent-v2/app.log

# ============================================
# 安全配置
# ============================================
MAX_FILE_SIZE=1048576
MAX_FILES_PER_PR=10
# 允许修改的文件扩展名（逗号分隔，可选）
# ALLOWED_FILE_EXTENSIONS=.py,.js,.ts,.json,.md,.yml,.yaml,.txt

# ============================================
# 重试配置
# ============================================
MAX_RETRIES=3
RETRY_DELAY=1.0
RETRY_BACKOFF=2.0

# ============================================
# 代理配置（如需要访问外网）
# ============================================
HTTP_PROXY=http://192.168.0.24:10808
HTTPS_PROXY=http://192.168.0.24:10808
ALL_PROXY=socks5://192.168.0.24:10808